# =============================================================================
# CAMINO — Variables de entorno
# Copia este archivo a .env.local y completa los valores.
# =============================================================================

# --- SUPABASE (obligatorio en producción) ------------------------------------
# Project Settings → Database → Connection string
# Recomendado para Cloudflare Workers: Transaction pooler (puerto 6543)
DATABASE_URL=postgresql://postgres:[PASSWORD]@localhost:5432/camino

# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Fuerza SSL si tu host lo exige y no se detecta automáticamente
# DATABASE_SSL=true

# --- GEMINI (opcional) -------------------------------------------------------
GEMINI_API_KEY=

# --- CRON DIARIO (recomendado) -----------------------------------------------
CRON_SECRET=

# --- WHATSAPP (opcional, solo moderadores) -----------------------------------
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ADMIN_PHONES=

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""
R2_BUCKET_NAME="camino-media"
R2_PUBLIC_URL=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
